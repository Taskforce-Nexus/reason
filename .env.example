# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic API (Claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001           # fast: Semilla chat, preguntas, voice
CLAUDE_MODEL_STRONG=claude-sonnet-4-20250514     # strong: debate, secciones, consultoría
CLAUDE_MODEL_REASONING=claude-opus-4-20250514    # reasoning: founder_brief, game_analysis

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=                     # sk_test_... — Stripe secret key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=    # pk_test_... — Stripe publishable key
STRIPE_WEBHOOK_SECRET=                 # whsec_... — webhook signing secret

# Stripe Price IDs — crear en Stripe Dashboard, luego pegar aquí
# Producto 1: Reason Core ($29/mes) — metadata.tier: core
STRIPE_PRICE_CORE=
# Producto 2: Reason Pro ($79/mes) — metadata.tier: pro
STRIPE_PRICE_PRO=
# Producto 3: Reason Enterprise ($199/mes) — metadata.tier: enterprise
STRIPE_PRICE_ENTERPRISE=
# Producto 4: Token Balance recargas (one-time)
STRIPE_PRICE_TOKEN_10=                 # $10 USD
STRIPE_PRICE_TOKEN_25=                 # $25 USD
STRIPE_PRICE_TOKEN_50=                 # $50 USD
STRIPE_PRICE_TOKEN_100=                # $100 USD

# Voice stack
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
